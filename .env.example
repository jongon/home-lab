# Copia este archivo a .env y rellena tus propios valores.
#   cp .env.example .env
# NUNCA subas el .env real: contiene secretos.

# --- Comunes ---
PUID=1000
PGID=1000
TZ=Europe/Madrid
LAN_IP=192.168.1.5                       # IP de la Pi en tu LAN

# --- Jellyfin ---
JELLYFIN_EXTERNAL_URL=https://jellyfin.example.com
JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=changeme

# --- Pi-hole ---
PIHOLE_PASS=changeme

# --- Prowlarr ---
PROWLARR_USER=admin
PROWLARR_PASS=changeme

# --- Cloudflare DDNS (token de API) ---
CLOUDFLARE_TOKEN=changeme

# --- aMule ---
WEBUI_PWD=changeme
GUI_PWD=changeme

# --- OpenClaw ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=changeme          # openssl rand -hex 24

# --- Streamystats (Postgres) ---
SS_POSTGRES_PASSWORD=changeme            # openssl rand -hex 24
SS_SESSION_SECRET=changeme               # openssl rand -base64 32
SS_ENCRYPTION_KEY=changeme               # openssl rand -hex 16

# --- Meilisearch ---
MEILI_MASTER_KEY=changeme                # openssl rand -base64 32

# --- Samba ---
SMB_PASS=changeme

# --- digarr ---
DIGARR_ENCRYPTION_KEY=changeme           # openssl rand -hex 32
LIDARR_API_KEY=changeme
AI_API_KEY=changeme                      # p.ej. clave de OpenAI (sk-...)
